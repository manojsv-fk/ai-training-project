# filepath: market-research-platform/.env.example
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── LlamaParse ──────────────────────────────────────────────────────────────
LLAMA_CLOUD_API_KEY=llx-...

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=mrip
POSTGRES_PASSWORD=mrip_secret
POSTGRES_DB=market_research
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── News APIs ───────────────────────────────────────────────────────────────
NEWSAPI_KEY=...
# Google News RSS requires no API key

# ─── App Config ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# ─── Scheduler ───────────────────────────────────────────────────────────────
NEWS_SYNC_INTERVAL_MINUTES=60
WEEKLY_BRIEF_CRON=0 8 * * 1
